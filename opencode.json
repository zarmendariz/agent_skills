{
  "$schema": "https://app.kilo.ai/config.json",
  "provider": {
    "kilo": {
      "options": {}
    }
  },
  "mcp": {},
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "rm *": "deny"
    },
    "edit": "deny",
